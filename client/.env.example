# Configuración del Cliente (OPCIONAL - solo para desarrollo local)

# URL de la API del servidor
# Si no está configurada, usa producción: https://iglesia-backend.onrender.com
# Para desarrollo local, descomenta y usa:
# VITE_API_URL=http://localhost:3001

# Client ID de PayPal Live (REQUERIDO)
